---
import Button from '../ui/button.astro';
import siteData from '../../content/site.json';

interface Slide {
  badge: string;
  titleTop: string;
  titleBottom: string;
  description: string;
}

interface Stat {
  value: string;
  label: string;
}

const { hero } = siteData as {
  hero: { ctaText: string; slides: Slide[]; stats: Stat[] };
};

const { slides, stats, ctaText } = hero;
const total = slides.length;
const duration = 4; // segundos por slide
const cycleDur = total * duration;
---

<section id="inicio" class="relative min-h-screen flex items-center overflow-hidden">
  <!-- Video background -->
  <video autoplay muted loop playsinline aria-hidden="true" class="absolute inset-0 w-full h-full object-cover">
    <source src="/vid_bg.mp4" type="video/mp4" />
  </video>

  <!-- Overlay oscuro suave -->
  <div class="absolute inset-0 bg-black/30"></div>
  <div class="absolute bottom-0 inset-x-0 h-4/5 bg-gradient-to-t from-emerald-300 to-transparent"></div>

  <!-- Contenido -->
  <div class="relative z-10 w-full pt-28 pb-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-8">
      <div class="w-full lg:max-w-3xl mx-auto lg:mx-0 text-center lg:text-left text-white">

        <!-- Contenedor de slides (mismo espacio) -->
        <div class="hero-slides mb-10">
          {slides.map((slide, i) => (
            <div
              class="hero-slide"
              style={`animation-duration: ${cycleDur}s; animation-delay: ${i * duration}s;`}
            >
              <span class="text-md uppercase mb-5 block tracking-[0.25em] font-semibold text-white text-shadow-md">
                {slide.badge}
              </span>

              <h1 class="leading-[1.1] mb-6 text-white text-shadow-lg">
                <span class="block text-4xl lg:text-6xl">{slide.titleTop}</span>
                <span class="block text-6xl xl:text-7xl">{slide.titleBottom}</span>
              </h1>

              <p class="lg:text-lg leading-relaxed mb-10 mx-auto lg:mx-0 text-white/80 max-w-xl">
                {slide.description}
              </p>
            </div>
          ))}
        </div>

        <Button text={ctaText} href="#contacto" variant="primary" size="lg" />

        <!-- Stats -->
        {stats?.length > 0 && (
          <div class="flex flex-wrap gap-8 mt-12 justify-center lg:justify-start">
            {stats.map((stat) => (
              <div class="text-center lg:text-left">
                <div class="text-3xl font-bold font-serif text-shadow-md">{stat.value}</div>
                <div class="text-md">{stat.label}</div>
              </div>
            ))}
          </div>
        )}

      </div>
    </div>
  </div>

  <!-- Flecha animada -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-10">
    <svg class="w-10 h-10 animate-bounce text-sky-950/60" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
    </svg>
  </div>
</section>

<style>
  /* Slides en grid (todos en la misma celda) */
  .hero-slides {
    display: grid;
  }
  .hero-slides > * {
    grid-area: 1 / 1;
  }

  /* Animación de ciclo (fade + slide) */
  .hero-slide {
    opacity: 0;
    transform: translateY(8px);
    animation-name: slide-cycle;
    animation-timing-function: ease;
    animation-iteration-count: infinite;
    animation-fill-mode: both;
    pointer-events: none;
  }

  /* El primer slide visible inmediatamente (sin esperar delay) */
  .hero-slide:first-child {
    animation-delay: 0s !important;
  }

  @keyframes slide-cycle {
    0%   { opacity: 0; transform: translateY(8px); pointer-events: none; }
    1.5% { opacity: 1; transform: translateY(0);   pointer-events: auto; }
    23%  { opacity: 1; transform: translateY(0);   pointer-events: auto; }
    25%  { opacity: 0; transform: translateY(-6px); pointer-events: none; }
    100% { opacity: 0; transform: translateY(8px); pointer-events: none; }
  }

  /* Respetar preferencias de movimiento reducido */
  @media (prefers-reduced-motion: reduce) {
    .hero-slide {
      animation: none;
      opacity: 0;
    }
    .hero-slide:first-child {
      opacity: 1;
      transform: none;
    }
  }
</style>