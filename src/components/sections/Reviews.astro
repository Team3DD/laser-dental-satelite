---
import siteData from '../../content/site.json';

const testimonials = siteData.testimonials || [];
const extended = [...testimonials, ...testimonials];

const col1 = extended.filter((_, i) => i % 3 === 0);
const col2 = extended.filter((_, i) => i % 3 === 1);
const col3 = extended.filter((_, i) => i % 3 === 2);

const columns = [
  { items: col1, animation: 'animate-scroll-down', slow: false },
  { items: col2, animation: 'animate-scroll-up',   slow: false },
  { items: col3, animation: 'animate-scroll-down', slow: true  },
];
---

<section id="reviews" class="py-4 sm:py-14 overflow-hidden bg-gradient-to-b from-emerald-700 to-transparent" aria-labelledby="reviews-heading">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-20">
      <span class="text-sm tracking-[0.7em] uppercase mb-4 block font-semibold text-white/90">
        {siteData.reviewsPage.label}
      </span>
      <h2 id="reviews-heading" class="text-4xl md:text-7xl leading-tight text-white">
        {siteData.reviewsPage.title}
      </h2>
    </div>

    <div class="relative">

      <!-- Mobile -->
      <div class="md:hidden h-[560px] overflow-hidden">
        <div class="animate-scroll-down flex flex-col gap-4" style="animation-duration: 60s;">
          {extended.map((item) => (
            <div class="liquid-glass rounded-3xl flex flex-col">
              <div class="relative z-10 p-5 flex flex-col">
                <p class="text-base leading-relaxed mb-4 italic text-center text-emerald-900"
                   style="font-family:'Playfair Display',Georgia,serif;">
                  "{item.text}"
                </p>
                <div class="flex items-end justify-between gap-4">
                  <div>
                    <p class="text-sm font-bold text-emerald-800">{item.name}</p>
                    {item.location && <p class="text-xs opacity-70 mt-0.5 text-emerald-600">{item.location}</p>}
                  </div>
                  {item.service && (
                    <span class="text-xs px-3 py-1 rounded-full whitespace-nowrap backdrop-blur-sm bg-white/10 border border-white/30 text-emerald-900">
                      {item.service}
                    </span>
                  )}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Desktop -->
      <div class="hidden md:grid md:grid-cols-3 gap-6 h-[620px]">
        {columns.map((col) => (
          <div class="overflow-hidden relative">
            <div class={`${col.animation} flex flex-col gap-6`}
                 style={col.slow ? 'animation-duration: 26s;' : ''}>
              {col.items.map((item) => (
                <div class="liquid-glass rounded-3xl flex flex-col">
                  <div class="relative z-10 p-6 flex flex-col">
                    <p class="text-xl leading-relaxed mb-6 italic text-center text-emerald-900"
                       style="font-family:'Playfair Display',Georgia,serif;">
                      "{item.text}"
                    </p>
                    <div class="mt-auto flex items-end justify-between gap-4 pt-4">
                      <div>
                        <p class="text-base font-bold text-emerald-800">{item.name}</p>
                        {item.location && <p class="text-sm opacity-70 mt-0.5 text-emerald-600">{item.location}</p>}
                      </div>
                      {item.service && (
                        <span class="text-xs px-4 py-1.5 rounded-full whitespace-nowrap backdrop-blur-sm bg-white/10 border border-white/30 text-emerald-900">
                          {item.service}
                        </span>
                      )}
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<style>
  #reviews:hover .animate-scroll-down,
  #reviews:hover .animate-scroll-up {
    animation-play-state: paused;
  }
</style>