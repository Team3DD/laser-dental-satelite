---
import siteData from '../../content/site.json';

const { contactPage } = siteData;
const {
  badge, title, description,
  address, schedule,
  formTitle, formDescription, formFields,
  submitButton, successMessage, errorMessage,
  errorAppointmentType, sundayMessage,
  whatsappNumber,
} = contactPage;

const daysMap = {
  monday: 'Lunes', tuesday: 'Martes', wednesday: 'Miércoles',
  thursday: 'Jueves', friday: 'Viernes', saturday: 'Sábado', sunday: 'Domingo',
} as const;

const scheduleText = 'Lunes a viernes 9:00–18:00 · Sábados 9:00–13:00';

const mapsUrl        = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`;
const fallbackEmbed  = `https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3761.5!2d-99.2!3d19.5!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1f8b5e5e5e5e5%3A0x0!2zQ2lydWphbm9zIDIyQSwgQ2QuIFNhdMOpbGl0ZSwgNTMxMDAgTmF1Y2FscGFuIGRlIEp1w6FyZXosIE3DqXguLCBNw6l4aWNv!5e0!3m2!1ses!2smx!4v1`;
---

<section class="py-24 bg-gradient-to-t from-emerald-300 to-transparent" id="contacto">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <!-- Encabezado -->
    <div class="text-center mb-20">
      <span class="text-sm tracking-[0.7em] uppercase mb-4 block font-semibold text-emerald-800">{badge}</span>
      <h2 class="text-4xl md:text-7xl leading-tight text-emerald-900 text-shadow-md">{title}</h2>
      <p class="text-lg max-w-3xl mx-auto mt-6 text-emerald-900/80">{description}</p>
    </div>

    <div class="grid lg:grid-cols-2 gap-12 items-stretch">

      <!-- ── Columna izquierda: mapa + dirección ── -->
      <div class="flex flex-col gap-4 h-full ">
        <div class="liquid-glass overflow-hidden rounded-3xl flex-1 relative" style="min-height:320px;">
          <iframe
            src={fallbackEmbed} width="100%" height="100%"
            style="border:0; position:absolute; inset:0; width:100%; height:100%;"
            allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"
            title="Ubicación Laser Dental Satélite"
          ></iframe>
        </div>

        <a href={mapsUrl} target="_blank" rel="noopener noreferrer"
           class="liquid-glass rounded-3xl p-6 text-center space-y-2 group block">
          <p class="font-semibold text-lg text-emerald-900">{address}</p>
          <p class="text-sm text-emerald-900/80">{scheduleText}</p>
        </a>
      </div>

      <!-- ── Columna derecha: formulario ── -->
      <div class="liquid-glass animated-border rounded-3xl p-8 flex flex-col relative z-20">
        <h3 class="mb-4 text-2xl md:text-3xl font-bold text-emerald-900 z-30">{formTitle}</h3>
        <p class="text-sm text-emerald-900/80 mb-6 z-30">{formDescription}</p>

        <div id="form-alerts" class="mb-4"></div>

        <form id="contact-form" class="flex flex-col gap-5 flex-1" novalidate>

          <!-- Nombre -->
          <div class="field-group">
            <label for="name" class="field-label">{formFields.name.label}</label>
            <input id="name" name="name" type="text"
              placeholder={formFields.name.placeholder} required class="form-field" />
          </div>

          <!-- Email + Teléfono -->
          <div class="grid sm:grid-cols-2 gap-4">
            <div class="field-group">
              <label for="email" class="field-label">{formFields.email.label}</label>
              <input id="email" name="email" type="email"
                placeholder={formFields.email.placeholder} required class="form-field" />
            </div>
            <div class="field-group">
              <label for="phone" class="field-label">{formFields.phone.label}</label>
              <input id="phone" name="phone" type="tel"
                placeholder={formFields.phone.placeholder} required class="form-field" />
            </div>
          </div>

          <!-- Tipo consulta + Fecha + Hora -->
          <div class="grid md:grid-cols-3 gap-4">

            <!-- Dropdown: tipo de consulta -->
            <div class="field-group">
              <label class="field-label">{formFields.appointmentType.label}</label>
              <div class="c-select" id="typeWrap">
                <button type="button" class="c-select__trigger" id="typeTrigger" aria-haspopup="listbox" aria-expanded="false">
                  <span id="typeLabel">Seleccione</span>
                  <svg class="c-select__chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <input type="hidden" id="appointmentType" name="appointmentType" required />
                <ul class="c-select__list bg-white rounded-2xl" role="listbox" id="typeList">
                  {formFields.appointmentType.options.map(opt => (
                    <li class="c-select__option" role="option" data-value={opt.value} tabindex="0">{opt.label}</li>
                  ))}
                </ul>
              </div>
            </div>

            <!-- Fecha -->
            <div class="field-group">
              <label for="preferredDate" class="field-label">{formFields.preferredDate.label}</label>
              <input type="date" id="preferredDate" name="preferredDate" class="form-field" />
            </div>

            <!-- Dropdown: hora -->
            <div class="field-group">
              <label class="field-label">{formFields.preferredTime.label}</label>
              <div class="c-select" id="timeWrap">
                <button type="button" class="c-select__trigger" id="timeTrigger" aria-haspopup="listbox" aria-expanded="false">
                  <span id="timeLabel">Seleccione</span>
                  <svg class="c-select__chevron" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                  </svg>
                </button>
                <input type="hidden" id="preferredTime" name="preferredTime" />
                <ul class="c-select__list bg-white rounded-2xl" role="listbox" id="timeList">
                  {formFields.preferredTime.options.map(time => (
                    <li class="c-select__option" role="option" data-value={time} tabindex="0">{time}</li>
                  ))}
                </ul>
              </div>
            </div>
          </div>

          <!-- Mensaje -->
          <div class="field-group">
            <label for="message" class="field-label">{formFields.message.label}</label>
            <textarea id="message" name="message" rows="3"
              placeholder={formFields.message.placeholder}
              class="form-field resize-y min-h-[80px] bg-white rounded-2xl"></textarea>
          </div>

          <!-- Submit -->
          <div class="flex justify-center mt-2">
            <button type="button" id="submit-btn" class="btn btn--primary btn--md liquid-glass">
              <span>{submitButton}</span>
            </button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Modal domingo -->
  <div id="sunday-modal" class="sunday-modal" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="sunday-modal__box liquid-glass rounded-3xl">
      <p class="text-emerald-900 text-base font-medium text-center">{sundayMessage}</p>
      <button type="button" id="sunday-close" class="btn btn--secondary btn--sm liquid-glass mt-4 mx-auto flex">
        <span>Entendido</span>
      </button>
    </div>
  </div>
</section>

<style>
  /* ── Tipografía del formulario ── */
  .field-group { display: flex; flex-direction: column; gap: 0.375rem; }
  .field-label  {
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: oklch(15% 0.06 220);          
  }

  /* ── Campos base ── */
  .form-field {
    width: 100%;
    padding: 0.7rem 0.875rem;
    border-radius: 0.75rem;
    border: 1px solid oklch(15% 0.06 220 / 0.15);
    background: oklch(100% 0 0 / 0.45);
    backdrop-filter: blur(8px);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    color: oklch(15% 0.06 220);
    outline: none;
    appearance: none;
    transition: border-color 0.2s ease, background 0.25s ease,
                backdrop-filter 0.25s ease, box-shadow 0.25s ease;
  }
  .form-field::placeholder { color: oklch(15% 0.06 220 / 0.4); }
  .form-field:hover {
    background: oklch(100% 0 0 / 0.68);
    backdrop-filter: blur(20px) saturate(180%);
    border-color: oklch(15% 0.06 220 / 0.3);
    box-shadow: inset 0 1px 0 oklch(100% 0 0 / 0.7), 0 2px 10px oklch(0% 0 0 / 0.07);
  }
  .form-field:focus {
    background: oklch(100% 0 0 / 0.8);
    backdrop-filter: blur(24px) saturate(200%);
    border-color: var(--color-clinical-blue);
    box-shadow: inset 0 1px 0 oklch(100% 0 0 / 0.8),
                0 0 0 3px oklch(45% 0.18 250 / 0.1);
  }

  /* ── Custom select ── */
  .c-select { position: relative; }

  .c-select__trigger {
    all: unset;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    width: 100%;
    padding: 0.7rem 0.875rem;
    border-radius: 0.75rem;
    border: 1px solid oklch(15% 0.06 220 / 0.15);
    background: oklch(100% 0 0 / 0.45);
    backdrop-filter: blur(8px);
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    color: oklch(15% 0.06 220);
    cursor: pointer;
    box-sizing: border-box;
    transition: border-color 0.2s ease, background 0.25s ease,
                backdrop-filter 0.25s ease, box-shadow 0.25s ease;
  }
  .c-select__trigger:hover,
  .c-select__trigger[aria-expanded="true"] {
    background: oklch(100% 0 0 / 0.68);
    backdrop-filter: blur(20px) saturate(180%);
    border-color: oklch(15% 0.06 220 / 0.3);
    box-shadow: inset 0 1px 0 oklch(100% 0 0 / 0.7), 0 2px 10px oklch(0% 0 0 / 0.07);
  }
  .c-select__trigger span {
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .c-select__chevron {
    width: 1rem; height: 1rem;
    opacity: 0.45;
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }
  .c-select__trigger[aria-expanded="true"] .c-select__chevron { transform: rotate(180deg); }

  .c-select__list {
    position: absolute;
    top: calc(100% + 6px);
    left: 0; right: 0;
    z-index: 60;
    margin: 0;
    padding: 0.375rem;
    list-style: none;
    max-height: 220px;
    overflow-y: auto;
    /* liquid-glass heredado de la clase global */
    opacity: 0;
    transform: translateY(-6px) scale(0.98);
    pointer-events: none;
    transition: opacity 0.2s var(--transition-ease, cubic-bezier(0.25,1,0.5,1)),
                transform 0.2s var(--transition-ease, cubic-bezier(0.25,1,0.5,1));
  }
  .c-select__list.is-open {
    opacity: 1;
    transform: none;
    pointer-events: auto;
  }
  .c-select__option {
    padding: 0.55rem 0.875rem;
    border-radius: 0.625rem;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 0.875rem;
    color: oklch(15% 0.06 220);
    cursor: pointer;
    transition: background 0.15s ease;
  }
  .c-select__option:hover,
  .c-select__option:focus { background: oklch(45% 0.18 250 / 0.08); outline: none; }
  .c-select__option[aria-selected="true"] {
    background: oklch(45% 0.18 250 / 0.12);
    font-weight: 600;
    color: var(--color-clinical-blue);
  }

  /* ── Modal domingo ── */
  .sunday-modal {
    position: fixed;
    inset: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    background: oklch(100% 0 0 / 0.35);
    backdrop-filter: blur(12px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }
  .sunday-modal.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .sunday-modal__box {
    max-width: 360px;
    width: 90%;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
</style>

<script define:vars={{ whatsappNumber, errorMessage, errorAppointmentType, successMessage, sundayMessage }}>
document.addEventListener('DOMContentLoaded', () => {

  /* ── Utilidad: custom select genérico ── */
  function initSelect(wrapperId, triggerId, labelId, listId, hiddenId, onSelect) {
    const wrap    = document.getElementById(wrapperId);
    const trigger = document.getElementById(triggerId);
    const label   = document.getElementById(labelId);
    const list    = document.getElementById(listId);
    const hidden  = document.getElementById(hiddenId);
    if (!wrap || !trigger || !label || !list || !hidden) return;

    const open  = () => { trigger.setAttribute('aria-expanded','true');  list.classList.add('is-open'); };
    const close = () => { trigger.setAttribute('aria-expanded','false'); list.classList.remove('is-open'); };

    trigger.addEventListener('click', e => { e.stopPropagation(); list.classList.contains('is-open') ? close() : open(); });

    list.querySelectorAll('.c-select__option').forEach(opt => {
      opt.addEventListener('click', () => {
        list.querySelectorAll('.c-select__option').forEach(o => o.removeAttribute('aria-selected'));
        opt.setAttribute('aria-selected', 'true');
        label.textContent = opt.textContent.trim();
        hidden.value      = opt.dataset.value;
        close();
        onSelect?.(opt.dataset.value);
      });
      opt.addEventListener('keydown', e => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); opt.click(); }
        if (e.key === 'Escape') { close(); trigger.focus(); }
      });
    });

    document.addEventListener('click', e => { if (!wrap.contains(e.target)) close(); });
  }

  /* ── Modal domingo ── */
  const sundayModal = document.getElementById('sunday-modal');
  const sundayClose = document.getElementById('sunday-close');
  const dateInput   = document.getElementById('preferredDate');

  const openSundayModal  = () => sundayModal?.classList.add('is-open');
  const closeSundayModal = () => {
    sundayModal?.classList.remove('is-open');
    if (dateInput) dateInput.value = '';
  };
  sundayClose?.addEventListener('click', closeSundayModal);
  sundayModal?.addEventListener('click', e => { if (e.target === sundayModal) closeSundayModal(); });

  /* Detectar domingo al cambiar fecha */
  dateInput?.addEventListener('change', () => {
    const d = new Date(dateInput.value + 'T12:00:00');
    if (d.getDay() === 0) openSundayModal();
  });

  /* Fecha mínima = hoy */
  if (dateInput) dateInput.min = new Date().toISOString().split('T')[0];

  /* ── Inicializar dropdowns ── */
  initSelect('typeWrap', 'typeTrigger', 'typeLabel', 'typeList', 'appointmentType');
  initSelect('timeWrap', 'timeTrigger', 'timeLabel', 'timeList', 'preferredTime');

  /* ── Blur overlay al enfocar formulario ── */
  const form = document.getElementById('contact-form');
  const formCard = form?.closest('.liquid-glass');
  if (formCard) formCard.style.zIndex = '40';

  let overlay = null;
  const getOverlay = () => {
    if (overlay) return overlay;
    overlay = Object.assign(document.createElement('div'), { id: 'form-blur' });
    Object.assign(overlay.style, {
      position:'fixed', inset:'0', background:'rgba(255,255,255,0.28)',
      backdropFilter:'blur(8px)', zIndex:'30', pointerEvents:'none',
      transition:'opacity 0.3s ease', opacity:'0', display:'none',
    });
    document.body.appendChild(overlay);
    return overlay;
  };
  const showBlur = () => {
    const o = getOverlay();
    o.style.display = 'block';
    requestAnimationFrame(() => { o.style.opacity = '1'; });
  };
  const hideBlur = () => {
    const o = getOverlay();
    o.style.opacity = '0';
    setTimeout(() => { o.style.display = 'none'; }, 300);
  };

  form?.addEventListener('focusin', showBlur);
  form?.addEventListener('focusout', e => { if (!form.contains(e.relatedTarget)) hideBlur(); });

  /* ── Alertas ── */
  const alertsEl = document.getElementById('form-alerts');
  let alertTimer;
  function showAlert(msg, type) {
    if (!alertsEl) return;
    clearTimeout(alertTimer);
    alertsEl.innerHTML = `<div class="${type === 'success' ? 'alert-success' : 'alert-error'}">${msg}</div>`;
    alertTimer = setTimeout(() => { alertsEl.innerHTML = ''; }, 5000);
  }

  /* ── Submit → WhatsApp ── */
  const typeLabels = {};
  document.querySelectorAll('#typeList .c-select__option').forEach(o => {
    if (o.dataset.value) typeLabels[o.dataset.value] = o.textContent.trim();
  });

  document.getElementById('submit-btn')?.addEventListener('click', () => {
    const v = id => document.getElementById(id)?.value?.trim() || '';
    const name   = v('name'), email = v('email'), phone = v('phone');
    const type   = v('appointmentType'), date = v('preferredDate'), time = v('preferredTime');
    const msg    = v('message');

    if (!name || !email || !phone) return showAlert(errorMessage, 'error');
    if (!type)                      return showAlert(errorAppointmentType, 'error');

    const dateStr = date
      ? new Date(date + 'T12:00:00').toLocaleDateString('es-MX', { weekday:'long', year:'numeric', month:'long', day:'numeric' })
      : '';

    const wa = `*SOLICITUD DE CITA*\n🏥 Laser Dental Satélite\n\n👤 *Paciente:*\n• Nombre: ${name}\n• Email: ${email}\n• Teléfono: ${phone}\n\n🩺 *Consulta:*\n• Tipo: ${typeLabels[type] || type}\n${dateStr ? `• Fecha: ${dateStr}\n` : ''}${time ? `• Hora: ${time}\n` : ''}\n📝 *Notas:*\n${msg || 'Sin comentarios'}\n\n---\nQuedo atento a su confirmación.`;

    window.open(`https://wa.me/${whatsappNumber}?text=${encodeURIComponent(wa)}`, '_blank');
    showAlert(successMessage, 'success');

    setTimeout(() => {
      form?.reset();
      document.getElementById('typeLabel').textContent = 'Seleccione';
      document.getElementById('timeLabel').textContent = 'Seleccione';
      document.querySelectorAll('.c-select__option').forEach(o => o.removeAttribute('aria-selected'));
      hideBlur();
    }, 3000);
  });
});
</script>