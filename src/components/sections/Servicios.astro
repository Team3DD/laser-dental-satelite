---
import Button from '../ui/button.astro';
import siteData from '../../content/site.json';

interface Servicio {
  name:        string;
  description: string;
  icon?:       string;
  image?:      string;
  badge?:      string;
}

const { servicios, serviciosPage } = siteData as {
  servicios:     Servicio[];
  serviciosPage: { label: string; title: string; description: string };
};
---

<section id="servicios" class="py-4 md:py-14 bg-gradient-to-b from-emerald-500 to-transparent">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">

    <div class="text-center mb-16">
      <span class="text-sm tracking-[0.7em] uppercase mb-4 block font-semibold text-white text-shadow-md">
        {serviciosPage.label}
      </span>
      <h2 class="text-4xl md:text-7xl leading-tight text-white text-shadow-md">{serviciosPage.title}</h2>
      <p class="text-2xl max-w-3xl mx-auto mt-6 text-white/90 text-shadow-md">{serviciosPage.description}</p>
    </div>

    <ul class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 list-none">
      {servicios.map((s, i) => (
        <li>
          <div class="card card--media animated-border group relative" style="aspect-ratio: 3/4;">

            <!-- Toggle para móvil -->
            <input type="checkbox" id={`card-toggle-${i}`} class="sr-only peer" />

            {s.image
              ? <img
                  src={s.image}
                  alt={s.name}
                  width="400"
                  height="533"
                  loading={i < 3 ? 'eager' : 'lazy'}
                  decoding="async"
                  fetchpriority={i === 0 ? 'high' : 'auto'}
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 peer-checked:scale-110"
                />
              : <div class="absolute inset-0 flex items-center justify-center text-7xl bg-gradient-to-br from-sky-400/80 to-sky-600/60" aria-hidden="true">
                  {s.icon}
                </div>
            }

            <div class="absolute inset-0 bg-emerald-900/0 group-hover:bg-emerald-900/40 peer-checked:bg-emerald-900/40 transition-all duration-700" />

            {s.badge && (
              <span class="absolute top-4 left-4 z-10 text-xs px-4 py-1.5 rounded-full whitespace-nowrap backdrop-blur-sm bg-white/10 border border-white/30 shadow-sm text-white">
                {s.badge}
              </span>
            )}

            <!-- Label tap para móvil (visible solo en touch) -->
            <label
              for={`card-toggle-${i}`}
              class="absolute inset-0 z-20 cursor-pointer lg:hidden peer-checked:bottom-auto peer-checked:h-1/2"
              aria-label={`Ver más sobre ${s.name}`}
            />

            <!-- Panel -->
            <div class="card__panel peer-checked:translate-y-0">
              <h3 class="text-white font-semibold leading-snug drop-shadow-lg text-2xl mb-8">
                {s.name}
              </h3>
              <div class="card__panel-body peer-checked:opacity-100 peer-checked:translate-y-0">
                <p class="text-white/85 text-lg leading-relaxed mb-8">
                  {s.description}
                </p>
                <div class="flex justify-end relative z-30">
                  <Button text="Agendar cita" href="#contacto" variant="primary" size="sm" />
                </div>
              </div>
            </div>

          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  /* Panel más arriba — muestra título + algo del cuerpo */
  .card__panel {
    transform: translateY(calc(100% - 5rem));
  }

  /* Hover desktop */
  .card--media:hover .card__panel {
    transform: translateY(0);
  }

  /* Peer (checked) — mobile tap */
  .card__panel:has(~ *),
  .peer:checked ~ * .card__panel {
    transform: translateY(0);
  }

  /* Body visible en peer checked */
  .card__panel-body.peer-checked\:opacity-100 {
    opacity: 1;
    transform: translateY(0);
  }
</style>