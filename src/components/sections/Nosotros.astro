---
import siteData from '../../content/site.json';
const { nosotros } = siteData;

const carouselImages = Array.from({ length: 14 }, (_, i) =>
  `/servicios/laserdental${String(i + 1).padStart(2, '0')}.jpg`
);
---

<section id="nosotros" class="py-24 bg-gradient-to-t from-emerald-300 to-transparent">
  <div class="max-w-7xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-20">
      <span class="text-sm tracking-[0.7em] uppercase mb-4 block font-semibold text-emerald-800">
        Nosotros
      </span>
      <h2 id="reviews-heading" class="text-4xl md:text-7xl leading-tight text-emerald-900 text-shadow-md">
        Toda una vida creando sonrisas
      </h2>
    </div>
    <div class="grid md:grid-cols-4 md:grid-rows-[300px_300px] gap-6 mb-20">

      <!-- Video principal (2x2) -->
      <div class="relative rounded-3xl overflow-hidden h-[500px] md:h-auto md:col-span-2 md:row-span-2">
        <video autoplay muted loop playsinline
               class="absolute inset-0 w-full h-full object-cover">
          <source src="/vid_bg.mp4" type="video/mp4" />
        </video>
        <div class="absolute bottom-8 left-8 right-8 bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-emerald-700/30 shadow-lg">
          <div class="flex items-start gap-3">
            <svg class="w-7 h-7 flex-shrink-0 mt-0.5 text-emerald-900" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
            </svg>
            <div>
              <h3 class="text-2xl font-medium mb-1 text-emerald-900 italic">{nosotros.videoCardTitle}</h3>
              <p class="text-md text-emerald-700 leading-relaxed">{nosotros.videoCardDescription}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Misión -->
      <div class="liquid-glass animated-border rounded-3xl p-6 md:p-8 flex flex-col justify-center md:col-span-2">
        <h3 class="text-3xl md:text-4xl font-bold mb-6 text-emerald-900" style="font-family:'Playfair Display',Georgia,serif;">
          Misión
        </h3>
          {nosotros.mission.map((line) => (
            <p class="leading-relaxed text-base text-emerald-700 mb-4">{line}</p>
          ))}
      </div>

      <!-- Visión -->
      <div class="liquid-glass animated-border rounded-3xl p-6 md:p-8 flex flex-col justify-center md:col-span-2">
        <h3 class="text-3xl md:text-4xl font-bold mb-6 text-emerald-900" style="font-family:'Playfair Display',Georgia,serif;">
          Visión
        </h3>
          {nosotros.vision.map((line) => (
            <p class="leading-relaxed text-base text-emerald-700 mb-4">{line}</p>
          ))}
      </div>
    </div>

    <!-- Segunda fila: carrusel + texto -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center py-10">

      <!-- Carrusel -->
      <div class="relative aspect-[4/5] rounded-3xl overflow-hidden shadow-lg">
        <div class="carousel-track absolute inset-0">
          {[...carouselImages, ...carouselImages].map((src, i) => (
            <img
              src={src}
              alt={`Laser Dental Satélite ${(i % 14) + 1}`}
              width="600" height="750"
              loading={i < 2 ? 'eager' : 'lazy'}
              decoding="async"
              class="carousel-slide absolute inset-0 w-full h-full object-cover"
              style={`opacity: ${i === 0 ? 1 : 0}; transition: opacity 0.8s ease;`}
            />
          ))}
        </div>

        <!-- Dots -->
        <div class="absolute bottom-4 left-0 right-0 flex justify-center gap-2 z-10">
          {carouselImages.map((_, i) => (
            <button
              type="button"
              class="carousel-dot w-2 h-2 rounded-full bg-white/50 transition-all duration-300"
              data-index={i}
              aria-label={`Imagen ${i + 1}`}
            />
          ))}
        </div>
      </div>

      <!-- Texto -->
      <div>
        <span class="text-sm tracking-[0.3em] uppercase mb-4 block font-semibold text-emerald-800">
          {nosotros.expertBadge}
        </span>
        <h2 class="text-4xl md:text-5xl leading-tight mb-6 text-emerald-900 text-shadow-md"
            style="font-family:'Playfair Display',Georgia,serif;">
          {nosotros.expertTitle}
        </h2>
        <p class="text-lg leading-relaxed mb-8 max-w-md text-emerald-700">
          {nosotros.expertDescription}
        </p>

        <div class="grid sm:grid-cols-2 gap-4">
          {nosotros.features.map((f: string) => (
            <div class="liquid-glass rounded-2xl p-5 group hover:scale-[1.02] transition-transform duration-300">
              <div class="inline-flex items-center justify-center w-9 h-9 rounded-full mb-3 text-emerald-900">
                <svg class="w-7 h-7 text-emerald-900" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
                </svg>
              </div>
              <p class="text-md font-medium text-emerald-900">{f}</p>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Banner valores -->
    <div class="mt-20 liquid-glass rounded-3xl">
      <div class="rounded-3xl relative overflow-hidden min-h-[400px]">
        <img
          src="/servicios/laserdental08.jpg"
          alt="Consulta dental moderna Laser Dental Satélite"
          width="1400" height="600"
          loading="lazy"
          decoding="async"
          class="absolute inset-0 w-full h-full object-cover"
        />
        <div class="absolute inset-0 bg-black/40" />
        <div class="relative z-10 p-12 md:p-16 flex flex-col justify-center min-h-[400px] max-w-2xl">
          <h3 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white text-shadow-md mb-2"
              style="font-family:'Playfair Display',Georgia,serif;">
            {nosotros.bannerTitle}
          </h3>
          <p class="text-white/80 text-2xl mb-8">{nosotros.bannerSubtitle}</p>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {nosotros.values.map((v: string) => (
              <div class="flex items-center gap-3 text-white/80">
                <svg class="w-7 h-7 flex-shrink-0 text-white/90" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
                </svg>
                <span>{v}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .carousel-slide { will-change: opacity; }
</style>

<script>
  const slides   = document.querySelectorAll<HTMLElement>('.carousel-slide');
  const dots     = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
  const total    = dots.length;
  let current    = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].style.opacity = '0';
    dots[current].classList.remove('bg-white', 'scale-125');
    dots[current].classList.add('bg-white/50');

    current = index % total;

    slides[current].style.opacity = '1';
    dots[current].classList.add('bg-white', 'scale-125');
    dots[current].classList.remove('bg-white/50');
  }

  function next() { goTo((current + 1) % total); }

  function startTimer() { timer = setInterval(next, 3500); }
  function resetTimer()  { clearInterval(timer); startTimer(); }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => { goTo(i); resetTimer(); });
  });

  goTo(0);
  startTimer();
</script>