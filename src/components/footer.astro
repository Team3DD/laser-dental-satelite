  facebook: 'M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z',
  twitter: 'M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z',
};

const contactIcons = {
  phone: 'M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 0 0 2.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 0 1-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 0 0-1.091-.852H4.5A2.25 2.25 0 0 0 2.25 4.5v2.25z',
  email: 'M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75',
  location: 'M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0z',
};
---

<footer class="relative overflow-hidden pt-14 pb-8 bg-emerald-800">

  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 pointer-events-none select-none z-0">
    <span class="font-['Playfair_Display'] font-bold text-white/3 whitespace-nowrap leading-none"
          style="font-size: clamp(80px, 18vw, 320px);">
      {siteTitle}
    </span>
  </div>

  <div class="max-w-7xl mx-auto px-6 lg:px-8 relative z-10">

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-10 mb-10">

      <!-- Columna 1: logo + descripción + redes -->
      <div class="col-span-1 text-center">
        <div class="group flex flex-col items-center gap-0 mb-4">
          <a href="/" class="relative w-32 h-14 block">
            <img
              src="/logoNegro.png"
              alt="Láser Dental Satélite"
              class="absolute inset-0 w-full h-full object-contain transition-opacity duration-200 opacity-0 group-hover:opacity-0"
            />
            <img
              src="/logoBlanco.png"
              alt="Láser Dental Satélite"
              class="absolute inset-0 w-full h-full object-contain transition-opacity duration-200 opacity-100 group-hover:opacity-100"
            />
          </a>
        </div>
        <p class="text-xs text-white/60 leading-relaxed mb-5 max-w-xs mx-auto">{footer.about}</p>
        <div class="flex justify-center gap-3">
          {footer.social?.instagram && (
            <Button variant="circle" size="md" href={footer.social.instagram} ariaLabel="Instagram">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d={socialIcons.instagram} />
              </svg>
            </Button>
          )}
          {footer.social?.facebook && (
            <Button variant="circle" size="md" href={footer.social.facebook} ariaLabel="Facebook">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d={socialIcons.facebook} />
              </svg>
            </Button>
          )}
          {footer.social?.twitter && (
            <Button variant="circle" size="md" href={footer.social.twitter} ariaLabel="Twitter / X">
              <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d={socialIcons.twitter} />
              </svg>
            </Button>
          )}
        </div>
      </div>

      <!-- Columnas 2, 3 y 4: en una fila en móvil -->
      <div class="grid grid-cols-2 md:contents gap-4 mt-6 md:mt-0">


        <!-- Explorar -->
        <div class="text-center">
          <h4 class="font-semibold text-white mb-3 text-xs tracking-wide uppercase">Explorar</h4>
          <ul class="list-none p-0 space-y-2">
            {footer.exploreLinks.map((link) => (
              <li>
                <a href={link.link} class="text-xs text-white/60 hover:text-white transition-colors inline-block">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Legal -->
        <div class="text-center">
          <h4 class="font-semibold text-white mb-3 text-xs tracking-wide uppercase">Legal</h4>
          <ul class="list-none p-0 space-y-2">
            {footer.links.map((link) => (
              <li>
                <a href={link.link} class="text-xs text-white/60 hover:text-white transition-colors inline-block">
                  {link.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Contacto -->
        <div class="text-center hidden md:block">
          <h4 class="font-semibold text-white mb-3 text-xs tracking-wide uppercase">Contacto</h4>
          <ul class="list-none p-0 space-y-2">
            {contacto?.telefono && (
              <li class="flex justify-center items-center gap-1.5 text-xs text-white/60">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={contactIcons.phone} />
                </svg>
                <a href={`tel:${contacto.telefono}`} class="hover:text-white transition-colors">{contacto.telefono}</a>
              </li>
            )}
            {contacto?.email && (
              <li class="flex justify-center items-center gap-1.5 text-xs text-white/60">
                <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={contactIcons.email} />
                </svg>
                <a href={`mailto:${contacto.email}`} class="hover:text-white transition-colors">{contacto.email}</a>
              </li>
            )}
            {contacto?.direccion && (
              <li class="flex justify-center items-start gap-1.5 text-xs text-white/60">
                <svg class="w-3.5 h-3.5 flex-shrink-0 mt-0.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d={contactIcons.location} />
                </svg>
                <span>{contacto.direccion}</span>
              </li>
            )}
          </ul>
        </div>

      </div>
    </div>

    <!-- Línea inferior -->
    <div class="pt-6 border-t border-white/10 flex flex-col md:flex-row items-center justify-between gap-3">
      <div class="flex flex-col items-center md:items-start gap-1">
        <p class="text-xs text-white/40">
          {footer.copyright.text
            .replace('{year}', new Date().getFullYear().toString())
            .replace('{siteTitle}', siteTitle)}
        </p>
        <p class="text-gray-400 text-xs">
          {footer.copyright.designCredit.text}{" "}
          {footer.copyright.designCredit.url ? (
            <a href={footer.copyright.designCredit.url} class="text-sky-400 hover:text-white transition-colors font-medium">
              {footer.copyright.designCredit.name}
            </a>
          ) : (
            <span class="text-sky-400 font-medium">{footer.copyright.designCredit.name}</span>
          )}
        </p>
      </div>
      <div class="flex gap-5">
        {footer.legalLinks.map((link) => (
          <a href={link.link} class="text-xs text-white/40 hover:text-white/70 transition-colors">{link.name}</a>
        ))}
      </div>
    </div>

  </div>
</footer>