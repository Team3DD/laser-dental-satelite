---
import siteData from '../content/site.json';
import Button from './ui/button.astro';

interface SiteData {
  siteTitle: string;
  siteSubtitle: string;
  footer: {
    about: string;
    links: Array<{ name: string; link: string }>;
    exploreLinks: Array<{ name: string; link: string }>;
    legalLinks: Array<{ name: string; link: string }>;
    social?: {
      instagram?: string;
      facebook?: string;
      twitter?: string;
    };
    copyright: {
      text: string;
      designCredit: {
        text: string;
        name: string;
        url?: string;
      };
    };
  };
  contacto: {
    telefono?: string;
    email?: string;
    direccion?: string;
  };
}

const { footer, siteTitle, siteSubtitle, contacto } = siteData as SiteData;

const socialIcons = {
